{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Safe Send (dev)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": ["--flavor", "dev"],
            // Ensure `pod` (CocoaPods) is on PATH when VS Code's GUI process has
            // a stripped PATH — pod lives in /usr/local/bin, gem bins in ~/.gem.
            "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:HOME}/.gem/bin:${env:PATH}" }
        },
        {
            "name": "Safe Send (dev · profile)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "flutterMode": "profile",
            "args": ["--flavor", "dev"],
            "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:HOME}/.gem/bin:${env:PATH}" }
        },
        {
            "name": "Safe Send (prod)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prod.dart",
            "args": ["--flavor", "prod"],
            "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:HOME}/.gem/bin:${env:PATH}" }
        },
        {
            "name": "Safe Send (prod · release)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prod.dart",
            "flutterMode": "release",
            "args": ["--flavor", "prod"],
            "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:HOME}/.gem/bin:${env:PATH}" }
        }
    ]
}
